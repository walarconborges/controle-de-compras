generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id           Int       @id @default(autoincrement())
  nome         String
  sobrenome    String    @default("")
  email        String    @unique
  senhaHash    String    @map("senha_hash")
  papelGlobal  String    @default("usuario") @map("papel_global")
  grupoAtivoId Int?      @map("grupo_ativo_id")
  ativo        Boolean   @default(true)
  desativadoEm DateTime? @map("desativado_em")
  excluidoEm   DateTime? @map("excluido_em")
  criadoEm     DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  grupoAtivo     Grupo?                @relation("UsuarioGrupoAtivo", fields: [grupoAtivoId], references: [id], onDelete: SetNull)
  usuariosGrupos UsuarioGrupo[]
  compras        Compra[]
  movimentacoes  MovimentacaoEstoque[]
  logsAutor      AuditoriaLog[]        @relation("AuditoriaAutor")

  @@index([email])
  @@index([papelGlobal])
  @@index([grupoAtivoId])
  @@index([ativo])
  @@map("usuarios")
}

model Grupo {
  id           Int       @id @default(autoincrement())
  nome         String    @unique
  codigo       String    @unique
  desativadoEm DateTime? @map("desativado_em")
  excluidoEm   DateTime? @map("excluido_em")
  criadoEm     DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  usuariosAtivos Usuario[]             @relation("UsuarioGrupoAtivo")
  usuariosGrupos UsuarioGrupo[]
  grupoItens     GrupoItem[]
  compras        Compra[]
  movimentacoes  MovimentacaoEstoque[]
  logs           AuditoriaLog[]

  @@index([codigo])
  @@index([excluidoEm])
  @@map("grupos")
}

model UsuarioGrupo {
  id               Int       @id @default(autoincrement())
  usuarioId        Int       @map("usuario_id")
  grupoId          Int       @map("grupo_id")
  papel            String    @default("membro")
  status           String    @default("pendente")
  solicitadoEm     DateTime  @default(now()) @map("solicitado_em")
  aprovadoEm       DateTime? @map("aprovado_em")
  aprovadoPorEmail String?   @map("aprovado_por_email")
  removidoEm       DateTime? @map("removido_em")
  canceladoEm      DateTime? @map("cancelado_em")
  desativadoEm     DateTime? @map("desativado_em")
  excluidoEm       DateTime? @map("excluido_em")
  criadoEm         DateTime  @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  grupo   Grupo   @relation(fields: [grupoId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, grupoId])
  @@index([grupoId, status])
  @@index([usuarioId, status])
  @@index([aprovadoPorEmail])
  @@index([excluidoEm])
  @@map("usuarios_grupos")
}

model Categoria {
  id           Int      @id @default(autoincrement())
  nome         String   @unique
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  itens Item[]

  @@map("categorias")
}

model Item {
  id            Int       @id @default(autoincrement())
  categoriaId   Int       @map("categoria_id")
  nome          String    @unique
  desativadoEm  DateTime? @map("desativado_em")
  excluidoEm    DateTime? @map("excluido_em")
  criadoEm      DateTime  @default(now()) @map("criado_em")
  atualizadoEm  DateTime  @updatedAt @map("atualizado_em")

  categoria     Categoria             @relation(fields: [categoriaId], references: [id])
  grupoItens    GrupoItem[]
  compraItens   CompraItem[]
  movimentacoes MovimentacaoEstoque[]
  logs          AuditoriaLog[]

  @@index([categoriaId])
  @@index([excluidoEm])
  @@map("itens")
}

model GrupoItem {
  id           Int      @id @default(autoincrement())
  grupoId      Int      @map("grupo_id")
  itemId       Int      @map("item_id")
  quantidade   Decimal  @default(0) @db.Decimal(10, 2)
  comprar      Boolean  @default(false)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  grupo Grupo @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  item  Item  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([grupoId, itemId])
  @@index([grupoId])
  @@index([itemId])
  @@map("grupo_itens")
}

model Compra {
  id        Int      @id @default(autoincrement())
  grupoId   Int      @map("grupo_id")
  usuarioId Int      @map("usuario_id")
  criadoEm  DateTime @default(now()) @map("criado_em")

  grupo       Grupo        @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  usuario     Usuario      @relation(fields: [usuarioId], references: [id])
  compraItens CompraItem[]

  @@index([grupoId])
  @@index([usuarioId])
  @@map("compras")
}

model CompraItem {
  id            Int      @id @default(autoincrement())
  compraId      Int      @map("compra_id")
  itemId        Int      @map("item_id")
  nomeItem      String   @map("nome_item")
  quantidade    Decimal  @db.Decimal(10, 2)
  valorUnitario Decimal? @map("valor_unitario") @db.Decimal(10, 2)

  compra Compra @relation(fields: [compraId], references: [id], onDelete: Cascade)
  item   Item   @relation(fields: [itemId], references: [id])

  @@index([compraId])
  @@index([itemId])
  @@map("compra_itens")
}

model MovimentacaoEstoque {
  id         Int      @id @default(autoincrement())
  grupoId    Int      @map("grupo_id")
  itemId     Int      @map("item_id")
  usuarioId  Int      @map("usuario_id")
  tipo       String
  quantidade Decimal  @db.Decimal(10, 2)
  motivo     String?
  criadoEm   DateTime @default(now()) @map("criado_em")

  grupo   Grupo   @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  item    Item    @relation(fields: [itemId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([grupoId])
  @@index([itemId])
  @@index([usuarioId])
  @@index([tipo])
  @@map("movimentacoes_estoque")
}

model AuditoriaLog {
  id             Int      @id @default(autoincrement())
  entidade       String
  entidadeId     Int?     @map("entidade_id")
  acao           String
  descricao      String?
  usuarioAutorId Int?     @map("usuario_autor_id")
  autorEmail     String?  @map("autor_email")
  grupoId        Int?     @map("grupo_id")
  itemId         Int?     @map("item_id")
  statusHttp     Int?     @map("status_http")
  metadados      Json?
  criadoEm       DateTime @default(now()) @map("criado_em")

  usuarioAutor Usuario? @relation("AuditoriaAutor", fields: [usuarioAutorId], references: [id])
  grupo        Grupo?   @relation(fields: [grupoId], references: [id])
  item         Item?    @relation(fields: [itemId], references: [id])

  @@index([entidade])
  @@index([acao])
  @@index([grupoId])
  @@index([itemId])
  @@index([autorEmail])
  @@index([criadoEm])
  @@map("auditoria_logs")
}
